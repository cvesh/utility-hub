---
// Utility Hub - Homepage
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Utility Hub - Free Online Tools & Calculators"
  description="Free online utility tools: calculators, text tools, dev tools, image tools and design utilities. Fast, mobile-friendly, no signup required."
>
  <main class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-blue-600 to-indigo-700 text-white py-20">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Free Online Utility Tools</h1>
        <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
          Fast, free, and mobile-friendly tools for everyday tasks. No signup, no ads clutter, no backend.
        </p>
      </div>
    </section>

    <!-- Calculators -->
    <section class="max-w-6xl mx-auto px-4 py-12">
      <h2 class="text-2xl font-bold text-gray-800 mb-6">Calculators</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/tools/age-calculator" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">Age Calculator</h3>
          <p class="text-sm text-gray-500">Calculate exact age in years, months, days</p>
        </a>
        <a href="/tools/percentage-calculator" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">Percentage Calculator</h3>
          <p class="text-sm text-gray-500">Calculate percentages easily online</p>
        </a>
        <a href="/tools/date-difference-calculator" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">Date Difference Calculator</h3>
          <p class="text-sm text-gray-500">Find days between two dates</p>
        </a>
        <a href="/tools/compound-interest-calculator" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">Compound Interest Calculator</h3>
          <p class="text-sm text-gray-500">Calculate investment growth over time</p>
        </a>
        <a href="/tools/bmi-calculator" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">BMI Calculator</h3>
          <p class="text-sm text-gray-500">Check your Body Mass Index</p>
        </a>
      </div>
    </section>

    <!-- Text Tools -->
    <section class="bg-white py-12">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">Text Tools</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a href="/tools/word-counter" class="block p-4 bg-gray-50 rounded-lg shadow hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-800">Word Counter</h3>
            <p class="text-sm text-gray-500">Count words, characters, sentences online</p>
          </a>
          <a href="/tools/character-counter" class="block p-4 bg-gray-50 rounded-lg shadow hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-800">Character Counter</h3>
            <p class="text-sm text-gray-500">Count characters including and excluding spaces</p>
          </a>
          <a href="/tools/case-converter" class="block p-4 bg-gray-50 rounded-lg shadow hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-800">Case Converter</h3>
            <p class="text-sm text-gray-500">Convert text to upper, lower, title case</p>
          </a>
          <a href="/tools/remove-extra-spaces" class="block p-4 bg-gray-50 rounded-lg shadow hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-800">Remove Extra Spaces</h3>
            <p class="text-sm text-gray-500">Clean up unnecessary whitespace</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Dev Tools -->
    <section class="max-w-6xl mx-auto px-4 py-12">
      <h2 class="text-2xl font-bold text-gray-800 mb-6">Dev Tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/tools/json-formatter" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">JSON Formatter</h3>
          <p class="text-sm text-gray-500">Format, validate, and beautify JSON</p>
        </a>
        <a href="/tools/jwt-decoder" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">JWT Decoder</h3>
          <p class="text-sm text-gray-500">Decode and inspect JWT tokens</p>
        </a>
        <a href="/tools/uuid-generator" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">UUID Generator</h3>
          <p class="text-sm text-gray-500">Generate random UUIDs online</p>
        </a>
        <a href="/tools/base64-encoder-decoder" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">Base64 Encoder/Decoder</h3>
          <p class="text-sm text-gray-500">Encode and decode Base64 data</p>
        </a>
        <a href="/tools/timestamp-converter" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">Timestamp Converter</h3>
          <p class="text-sm text-gray-500">Convert Unix timestamps to dates</p>
        </a>
        <a href="/tools/regex-tester" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">Regex Tester</h3>
          <p class="text-sm text-gray-500">Test regular expressions in real-time</p>
        </a>
      </div>
    </section>

    <!-- Image/Media Tools -->
    <section class="bg-white py-12">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">Image & Media Tools</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a href="/tools/qr-code-generator" class="block p-4 bg-gray-50 rounded-lg shadow hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-800">QR Code Generator</h3>
            <p class="text-sm text-gray-500">Generate QR codes for any text or URL</p>
          </a>
          <a href="/tools/image-compressor" class="block p-4 bg-gray-50 rounded-lg shadow hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-800">Image Compressor</h3>
            <p class="text-sm text-gray-500">Compress images client-side</p>
          </a>
          <a href="/tools/image-resizer" class="block p-4 bg-gray-50 rounded-lg shadow hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-800">Image Resizer</h3>
            <p class="text-sm text-gray-500">Resize images to any dimensions</p>
          </a>
          <a href="/tools/webp-converter" class="block p-4 bg-gray-50 rounded-lg shadow hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-800">WebP Converter</h3>
            <p class="text-sm text-gray-500">Convert images to WebP format</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Design Tools -->
    <section class="max-w-6xl mx-auto px-4 py-12">
      <h2 class="text-2xl font-bold text-gray-800 mb-6">Design & Utility Tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/tools/color-picker" class="block p-4 bg-white rounded-lg shadow hover:shadow-md transition-shadow">
          <h3 class="font-semibold text-gray-800">Color Picker</h3>
          <p class="text-sm text-gray-500">Pick and convert colors between HEX and RGB</p>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-300 py-8">
      <div class="max-w-6xl mx-auto px-4 text-center text-sm">
        <p>&copy; 2026 Utility Hub. Free online tools for everyone.</p>
      </div>
    </footer>
  </main>
</Layout>
</write_to_file>
<task_progress>
- [x] Set up Astro project with dependencies
- [ ] Create project configuration files
- [ ] Generate 20 utility tools (CALCULATORS: 1-5)
- [ ] Generate 20 utility tools (TEXT TOOLS: 6-9)
- [ ] Generate 20 utility tools (DEV TOOLS: 10-15)
- [ ] Generate 20 utility tools (IMAGE/MEDIA: 16-19)
- [ ] Generate 20 utility tools (DESIGN: 20)
- [ ] Create shared components and layouts
- [ ] Verify project builds successfully
</task_write_to_file>